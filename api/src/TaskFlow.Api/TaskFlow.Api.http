@TaskFlow.Api_HostAddress = http://localhost:5080
@taskId = REPLACE_WITH_ID_FROM_CREATE_RESPONSE

### Health
GET {{TaskFlow.Api_HostAddress}}/health
Accept: application/json

### List all tasks
GET {{TaskFlow.Api_HostAddress}}/api/tasks
Accept: application/json

### Create a task
POST {{TaskFlow.Api_HostAddress}}/api/tasks
Content-Type: application/json

{
  "title": "Plan Q3 campaign",
  "description": "Coordinate creative + media",
  "priority": "High",
  "dueDate": "2026-06-30T00:00:00Z",
  "assignee": "Alex"
}

### Get a single task
GET {{TaskFlow.Api_HostAddress}}/api/tasks/{{taskId}}
Accept: application/json

### Update task details
PUT {{TaskFlow.Api_HostAddress}}/api/tasks/{{taskId}}
Content-Type: application/json

{
  "title": "Plan Q3 campaign refined scope",
  "description": "Pull in PR + paid",
  "priority": "High",
  "dueDate": "2026-07-15T00:00:00Z",
  "assignee": "Alex"
}

### Change status
PATCH {{TaskFlow.Api_HostAddress}}/api/tasks/{{taskId}}/status
Content-Type: application/json

{
  "status": "InProgress"
}

### Delete a task
DELETE {{TaskFlow.Api_HostAddress}}/api/tasks/{{taskId}}

### Validation error example (empty title)
POST {{TaskFlow.Api_HostAddress}}/api/tasks
Content-Type: application/json

{
  "title": "",
  "priority": "Medium"
}
